{
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projectId", "accepted"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "projectId": {
      "type": "string"
    },
    "accepted": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidateId", "family", "momentType"],
        "properties": {
          "candidateId": {
            "type": "string"
          },
          "family": {
            "type": "string",
            "enum": ["ding", "success"]
          },
          "momentType": {
            "type": "string"
          }
        }
      }
    }
  }
}
